{
  "info": {
    "name": "URL Shortener API - Postman Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Collection for Auth, Links, Clicks, Analytics and Webhooks endpoints"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"secret123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "register"
              ]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"secret123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "login"
              ]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "logout"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Links",
      "item": [
        {
          "name": "List Links",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/links",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "links"
              ],
              "query": [
                {
                  "key": "per_page",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Create Link",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"slug\": \"my-test-slug\",\n  \"target_url\": \"https://example.com/some-path\",\n  \"is_active\": true,\n  \"expires_at\": null\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/links",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "links"
              ]
            }
          }
        },
        {
          "name": "Get Link",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/links/{{linkId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "links",
                "{{linkId}}"
              ]
            }
          }
        },
        {
          "name": "Update Link",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"target_url\": \"https://example.com/updated\",\n  \"is_active\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/links/{{linkId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "links",
                "{{linkId}}"
              ]
            }
          }
        },
        {
          "name": "Delete Link",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/links/{{linkId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "links",
                "{{linkId}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Clicks",
      "item": [
        {
          "name": "Redirect (record click)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idempotency_key\": \"abc-123\",\n  \"referrer\": \"https://referrer.example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/r/{{slug}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "r",
                "{{slug}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Link Stats",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/links/{{linkId}}/stats",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "links",
                "{{linkId}}",
                "stats"
              ]
            }
          }
        },
        {
          "name": "Overview",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/analytics/overview",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "analytics",
                "overview"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Webhooks",
      "item": [
        {
          "name": "List Webhooks",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/webhooks",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "webhooks"
              ]
            }
          }
        },
        {
          "name": "Retry Webhook",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/webhooks/{{webhookId}}/retry",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "webhooks",
                "{{webhookId}}",
                "retry"
              ]
            }
          }
        }
      ]
    }
  ],
  "event": []
}
